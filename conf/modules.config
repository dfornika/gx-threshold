/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: FASTQC {
        ext.args = '--quiet'
    }

    withName: 'FASTP' {
        memory = { 4.GB * task.attempt }
    }

    withName: 'DEHOST' {
        // The dehosted, trimmed reads are the shareable artifact - publish them
        // to a dedicated directory alongside the per-sample dehosting stats.
        publishDir = [
            path: { "${params.outdir}/dehost" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'MASH_DIST' {
        ext.args   = '-r'
        publishDir = [
            path: { "${params.outdir}/mash" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SOURMASH_SKETCH' {
        ext.args   = "dna --param-string 'k=21,scaled=1000'" // match the k/scaled of tests/data/species_db/sourmash
        publishDir = [
            path: { "${params.outdir}/sourmash" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SOURMASH_GATHER' {
        // Default --threshold-bp (50kb) is larger than small/viral genomes
        // (e.g. SARS-CoV-2 is ~30kb) - lower it so gather can still report a hit.
        ext.args   = '--threshold-bp 1000'
        publishDir = [
            path: { "${params.outdir}/sourmash" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SYLPH_PROFILE' {
        publishDir = [
            path: { "${params.outdir}/sylph" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}
