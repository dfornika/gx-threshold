/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: 'FASTQC_RAW' {
        ext.args   = '--quiet'
        ext.prefix = { "${meta.id}_raw" }
    }

    withName: 'FASTQC_FINAL' {
        ext.args   = '--quiet'
        ext.prefix = { "${meta.id}_final" }
    }

    withName: 'FASTP_TRIM|FASTP_FINAL_QC' {
        memory = { 4.GB * task.attempt }
    }

    withName: 'FASTP_FINAL_QC' {
        // Measurement-only pass on the final reads - see
        // subworkflows/local/read_qc_and_dehosting.nf. discard_trimmed_pass:
        // true means fastp never writes trimmed reads at all here, so
        // distinguishing the report filename is just for clarity in MultiQC.
        ext.prefix = { "${meta.id}_final" }
    }

    withName: 'FASTPLONG_FINAL_QC' {
        ext.prefix = { "${meta.id}_final" }
    }

    withName: 'DEHOST' {
        // The dehosted, trimmed reads are the shareable artifact - publish them
        // to a dedicated directory alongside the per-sample dehosting stats.
        publishDir = [
            path: { "${params.outdir}/dehost" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'MASH_DIST' {
        ext.args   = '-r'
        publishDir = [
            path: { "${params.outdir}/mash" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SOURMASH_SKETCH' {
        ext.args   = "dna --param-string 'k=21,scaled=1000'" // match the k/scaled of tests/data/species_db/sourmash
        publishDir = [
            path: { "${params.outdir}/sourmash" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SOURMASH_GATHER' {
        // Default --threshold-bp (50kb) is larger than small/viral genomes
        // (e.g. SARS-CoV-2 is ~30kb) - lower it so gather can still report a hit.
        ext.args   = '--threshold-bp 1000'
        publishDir = [
            path: { "${params.outdir}/sourmash" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SYLPH_PROFILE' {
        publishDir = [
            path: { "${params.outdir}/sylph" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SPECIES_ID_SUMMARY_MASH|SPECIES_ID_SUMMARY_SOURMASH|SPECIES_ID_SUMMARY_SYLPH' {
        publishDir = [
            path: { "${params.outdir}/species_id" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'REFERENCE_GENOME_DISTANCES' {
        publishDir = [
            path: { "${params.outdir}/species_id" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CLUSTER_REFERENCE_GENOMES' {
        ext.args = "--ani-threshold ${params.species_composition_ani_threshold}"
        publishDir = [
            path: { "${params.outdir}/species_id" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SPECIES_COMPOSITION' {
        publishDir = [
            path: { "${params.outdir}/species_id" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'LIBRARY_TYPE' {
        publishDir = [
            path: { "${params.outdir}/library_type" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SELECT_REFERENCE_ACCESSION' {
        publishDir = [
            path: { "${params.outdir}/reference_genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'LIBRARY_TYPE_ALIGNED' {
        publishDir = [
            path: { "${params.outdir}/library_type" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'READ_OVERLAP' {
        publishDir = [
            path: { "${params.outdir}/library_type" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'LIBRARY_TYPE_CLUSTER' {
        publishDir = [
            path: { "${params.outdir}/library_type" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'ALIGN_READS' {
        publishDir = [
            path: { "${params.outdir}/library_type" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CLASSIFY_16S_AMPLICON' {
        publishDir = [
            path: { "${params.outdir}/library_type" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'LIBRARY_TYPE_PILEUP' {
        publishDir = [
            path: { "${params.outdir}/library_type" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}
