/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running full-size tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a full size pipeline test.

    Use as follows:
        nextflow run BCCDC-PHL/gx-threshold -profile test_full,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Realistic test dataset: small, downsampled real SRA reads (bacterial WGS + SARS-CoV-2 amplicon, Illumina + Nanopore). See tests/data/real/README.md for provenance.'

    // Real (downsampled) reads - see tests/data/real/README.md for source
    // SRA accessions and how they were subsampled.
    input = "${projectDir}/tests/data/real/samplesheet.csv"

    // Real human mitochondrial genome (rCRS, NC_012920.1) - a handful of
    // reads simulated from it are spiked into each sample (see
    // tests/data/real/README.md), so this profile also exercises real
    // host-read removal, unlike the plain SRA downloads.
    dehost_reference = "${projectDir}/tests/data/real/references/human_mt.fasta"

    // Tiny multi-species databases (see tests/data/species_db/README.md)
    // covering the true species of every sample here plus decoys, so each
    // species-ID call can be checked against a known answer.
    mash_db              = "${projectDir}/tests/data/species_db/mash/species_mini.msh"
    sourmash_db          = "${projectDir}/tests/data/species_db/sourmash/species_mini.sig.zip"
    sylph_db             = "${projectDir}/tests/data/species_db/sylph/species_mini.syldb"
    species_id_manifest  = "${projectDir}/tests/data/species_db/manifest.csv"

    // Reference-genome fetch does real NCBI network I/O - on by default for
    // real deployments (see nextflow.config), but this profile stays
    // offline/deterministic by default. See docs/testing.md for how to
    // opt back in (-profile test_full,dev,docker plus a -params-file
    // override) to exercise the alignment-based library-type methods too.
    skip_reference_genome_fetch = true

    // Assembly off here too: test_full's real reads are downsampled to ~1200
    // read pairs (a few thousand reads) - fine for the read-level analyses but
    // far too shallow to assemble meaningfully. Assembly is validated against
    // the deeper data/dev_samples/ isolates instead (see docs/testing.md).
    skip_assembly = true
}
