/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run BCCDC-PHL/gx-threshold -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    // Capped to fit a memory-constrained dev machine (~7 GB in WSL). This caps
    // every process request down to 6 GB, so process_medium tasks (e.g. DEHOST,
    // nominally 12 GB) still launch here. Bump this on machines with more RAM.
    resourceLimits = [
        cpus: 4,
        memory: '6.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data
    // Minimal paired-end Illumina samplesheet that matches this pipeline's platform
    // model (paired-end => illumina => FASTP => DEHOST). The upstream viralrecon
    // samplesheet includes a single-end sample with two fastqs, which this pipeline's
    // `single_end => nanopore` routing sends to fastplong and breaks - see docs.
    input  = "${projectDir}/assets/samplesheet_test.csv"

    // Tiny decoy host reference so the dehost step exercises its code path offline.
    // Real runs should point --dehost_reference at a masked human reference.
    dehost_reference = "${projectDir}/assets/dehost/decoy_host.fasta"
}
