/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run BCCDC-PHL/gx-threshold -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    // For memory-constrained machines (e.g. a laptop) compose with the `dev`
    // profile, which lowers these limits further: -profile test,dev,docker
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data: tiny in-repo synthetic fixtures (see tests/data/generate.py).
    // Covers both platforms - SAMPLE_PE (paired => illumina) and SAMPLE_ONT
    // (single-end => nanopore) - and the reads are a host+microbe mix so the
    // dehost step actually removes reads. Fully offline.
    input  = "${projectDir}/tests/data/samplesheet.csv"

    // Small synthetic host reference that the host-derived reads map to, so the
    // removal path is exercised. Real runs point --dehost_reference at a masked
    // human reference.
    dehost_reference = "${projectDir}/tests/data/references/host_mini.fasta"

    // Tiny species-ID databases (see tests/data/species_db/README.md). The
    // synthetic reads here are pseudo-random, so these won't return a
    // meaningful species call - they're exercised for real against known
    // species in the test_full profile instead.
    mash_db     = "${projectDir}/tests/data/species_db/mash/species_mini.msh"
    sourmash_db = "${projectDir}/tests/data/species_db/sourmash/species_mini.sig.zip"
    sylph_db    = "${projectDir}/tests/data/species_db/sylph/species_mini.syldb"
}
